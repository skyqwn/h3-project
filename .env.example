# Resend (transactional email for contact form)
RESEND_API_KEY=re_xxx
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=noreply@example.com

# Cloudflare Turnstile (contact form bot protection)
TURNSTILE_SECRET_KEY=0x4xxx
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4xxx

# Site URL — used for canonical URLs, sitemap, and OG image origins.
# Use http://localhost:3000 for local dev, your production URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
